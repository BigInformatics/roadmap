{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://biginformatics.github.io/roadmap/roadmap.schema.json",
  "title": "Product Roadmap Data",
  "description": "Schema for Product-Roadmap.html data. Accepts a single product roadmap object, an array of product roadmap objects, or the exported document-set wrapper used to preserve enabled/toggle state.",
  "oneOf": [
    {
      "$ref": "#/$defs/productRoadmap"
    },
    {
      "$ref": "#/$defs/productRoadmapArray"
    },
    {
      "$ref": "#/$defs/documentSet"
    }
  ],
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "not-started",
        "in-progress",
        "at-risk",
        "completed",
        "blocked",
        "on-hold",
        "cancelled"
      ]
    },
    "monthKey": {
      "type": "string",
      "pattern": "^(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec) [0-9]{4}$",
      "examples": [
        "May 2026",
        "Dec 2032"
      ]
    },
    "dateString": {
      "type": "string",
      "pattern": "^(0?[1-9]|1[0-2])/(0?[1-9]|[12][0-9]|3[01])/[0-9]{4}$",
      "examples": [
        "05/15/2026",
        "12/01/2028"
      ]
    },
    "dueDate": {
      "description": "Per-date schedule item. Status and note belong to this due date, not the whole deliverable.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "date"
      ],
      "properties": {
        "date": {
          "$ref": "#/$defs/dateString"
        },
        "status": {
          "$ref": "#/$defs/status",
          "default": "not-started"
        },
        "note": {
          "type": "string",
          "default": ""
        }
      }
    },
    "dueDateEntry": {
      "description": "Preferred entries are dueDate objects. Legacy MM/DD/YYYY strings are accepted and normalized by the UI.",
      "oneOf": [
        {
          "$ref": "#/$defs/dueDate"
        },
        {
          "$ref": "#/$defs/dateString"
        }
      ]
    },
    "deliverable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "owner",
        "status",
        "start",
        "end",
        "desc",
        "dueDates",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Unique within its product roadmap. The UI can auto-generate values such as bp-003; existing data may use shorter IDs such as bp-1."
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/status",
          "default": "not-started",
          "description": "Overall task status. Individual due-date chips and list rows use dueDates[].status."
        },
        "start": {
          "$ref": "#/$defs/monthKey"
        },
        "end": {
          "$ref": "#/$defs/monthKey"
        },
        "desc": {
          "type": "string"
        },
        "tags": {
          "description": "Optional comma-separated string or array of labels. The UI normalizes tags and can search them with the Tags toggle.",
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            {
              "type": "string"
            }
          ],
          "default": []
        },
        "favorite": {
          "description": "Optional flag for starring a task. Favorites can be filtered from the header.",
          "type": "boolean",
          "default": false
        },
        "dueDates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dueDateEntry"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "productRoadmap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "subtitle",
        "lastUpdated",
        "owner",
        "deliverables"
      ],
      "anyOf": [
        {
          "required": [
            "project"
          ]
        },
        {
          "required": [
            "product"
          ]
        }
      ],
      "properties": {
        "project": {
          "type": "string",
          "minLength": 1,
          "description": "Preferred product, project, or contract display name."
        },
        "product": {
          "type": "string",
          "minLength": 1,
          "description": "Legacy alias for project. The UI normalizes this into project."
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "subtitle": {
          "type": "string"
        },
        "lastUpdated": {
          "type": "string",
          "description": "Display timestamp such as YYYY-MM-DD HH:mm:ss ET. The UI updates this on save."
        },
        "owner": {
          "type": "string"
        },
        "deliverables": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/deliverable"
          }
        }
      }
    },
    "productRoadmapArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/productRoadmap"
      }
    },
    "documentEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "enabled",
        "data"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable editor-card/document ID."
        },
        "enabled": {
          "type": "boolean",
          "description": "Whether this product is visible in the combined roadmap."
        },
        "data": {
          "$ref": "#/$defs/productRoadmap"
        }
      }
    },
    "documentSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "documents"
      ],
      "properties": {
        "documents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/documentEnvelope"
          }
        }
      }
    }
  }
}
